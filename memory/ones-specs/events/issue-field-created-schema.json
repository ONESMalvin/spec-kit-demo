{
  "$schema": "http://json-schema.org/2020-12/schema#",
  "title": "Create Issue Field Event Schema",
  "description": "Create issue field event structure",
  "type": "object",
  "required": ["eventID", "eventType", "timestamp", "subscriberID", "eventData"],
  "properties": {
    "eventID": {
      "type": "string",
      "description": "Unique identifier for the event"
    },
    "eventType": {
      "type": "string",
      "enum": ["ones:setting:issue-field:created"],
      "description": "Type of the event"
    },
    "timestamp": {
      "type": "number",
      "description": "Timestamp when the event occurred"
    },
    "subscriberID": {
      "type": "string",
      "description": "ID of the subscriber"
    },
    "eventData": {
      "type": "object",
      "required": ["id", "name", "propertyTypeLabel"],
      "properties": {
        "organizationID": {
          "type": "string",
          "description": "Organization that triggered the event. May be empty."
        },
        "teamID": {
          "type": "string",
          "description": "Team that triggered the event. May be empty."
        },
        "triggerUserID": {
          "type": "string",
          "description": "User that triggered the event. May be empty."
        },
        "id": {
          "type": "string",
          "description": "ID of the issue field associated with the event."
        },
        "name": {
          "type": "string",
          "description": "Name of the issue field associated with the event."
        },
        "propertyTypeLabel": {
          "type": "string",
          "enum": [
            "appear_time",
            "date",
            "department_list",
            "float",
            "integer",
            "multi_line_text",
            "multi_option",
            "option",
            "project_list",
            "sprint",
            "stay_count",
            "stay_time",
            "step_range",
            "text",
            "time",
            "user",
            "user_list"
          ],
          "description": "Type label of the issue field."
        },
        "fieldSetting": {
          "$ref": "#/definitions/FieldSetting",
          "description": "Settings of the issue field."
        }
      }
    }
  },
  "definitions": {
    "FieldSetting": {
      "type": "object",
      "properties": {
        "option": {
          "$ref": "#/definitions/OptionInfo",
          "description": "Valid for type of issue field which is 'option' or 'multi_option'."
        },
        "stepRange": {
          "$ref": "#/definitions/StepRange",
          "description": "Valid for type of issue field which is 'step_range'."
        },
        "appearTime": {
          "$ref": "#/definitions/FieldWithMethod",
          "description": "Valid for type of issue field which is 'appear_time'."
        },
        "stay": {
          "$ref": "#/definitions/Field",
          "description": "Valid for type of issue field which is 'stay_time' or 'stay_count'."
        }
      }
    },
    "OptionInfo": {
      "type": "object",
      "properties": {
        "optionTotal": {
          "type": "number",
          "description": "Total number of the options"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Option"
          },
          "description": "Part of the option items (the maximum number is 1024)."
        }
      }
    },
    "Option": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "ID of the option."
        },
        "value": {
          "description": "Value of the option."
        }
      }
    },
    "StepRange": {
      "type": "object",
      "properties": {
        "start": {
          "$ref": "#/definitions/FieldWithMethod",
          "description": "Start time of the issue field."
        },
        "end": {
          "$ref": "#/definitions/FieldWithMethod",
          "description": "End time of the issue field."
        }
      }
    },
    "Field": {
      "type": "object",
      "properties": {
        "fieldType": {
          "type": "string",
          "description": "Type of the issue field."
        },
        "fieldID": {
          "type": "string",
          "description": "ID of the issue field associated with the event."
        },
        "fieldOptionID": {
          "type": "string",
          "description": "Option id of the issue field."
        }
      }
    },
    "FieldWithMethod": {
      "type": "object",
      "properties": {
        "fieldType": {
          "type": "string",
          "description": "Type of the issue field."
        },
        "fieldID": {
          "type": "string",
          "description": "ID of the issue field associated with the event."
        },
        "fieldOptionID": {
          "type": "string",
          "description": "Option id of the issue field."
        },
        "method": {
          "type": "string",
          "enum": ["first_at", "last_at"],
          "description": "first_at: the first appear time，last_at: the last appear time"
        }
      }
    }
  }
}
