{
  "$schema": "http://json-schema.org/2020-12/schema#",
  "title": "Update Issue Layout Event Schema",
  "description": "Update issue layout event structure",
  "type": "object",
  "required": ["eventID", "eventType", "timestamp", "subscriberID", "eventData"],
  "properties": {
    "eventID": {
      "type": "string",
      "description": "Unique identifier for the event"
    },
    "eventType": {
      "type": "string",
      "enum": ["ones:setting:issue-layout:updated"],
      "description": "Type of the event"
    },
    "timestamp": {
      "type": "number",
      "description": "Timestamp when the event occurred"
    },
    "subscriberID": {
      "type": "string",
      "description": "ID of the subscriber"
    },
    "eventData": {
      "type": "object",
      "required": ["id", "issueTypeID"],
      "properties": {
        "organizationID": {
          "type": "string",
          "description": "Organization that triggered the event. May be empty."
        },
        "teamID": {
          "type": "string",
          "description": "Team that triggered the event. May be empty."
        },
        "triggerUserID": {
          "type": "string",
          "description": "User that triggered the event. May be empty."
        },
        "id": {
          "type": "string",
          "description": "ID of the issue layout."
        },
        "issueTypeID": {
          "type": "string",
          "description": "Type of the issue."
        },
        "projectID": {
          "type": "string",
          "description": "Project ID which is valid for updating project local layout."
        }
      }
    }
  }
}
